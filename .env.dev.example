# Development Environment Variables
# Copy this file to .env for Docker development

# Django Settings
DEBUG=True
SECRET_KEY=dev-secret-key-change-me-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# MySQL Database Configuration (Docker)
DB_NAME=southeast_archers
DB_USER=root
MYSQL_ROOT_PASSWORD=devpassword
DB_HOST=db  # 'db' is the Docker Compose service name
DB_PORT=3306

# Host Port Mappings (optional - change if ports conflict)
WEB_PORT=8000
DB_PORT_HOST=3307

# Email Configuration (optional - console backend for dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
